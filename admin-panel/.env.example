# Скопировать в .env и заполнить реальными значениями.
# Этот файл НЕ должен попадать в git (см. .gitignore).

# БД — те же insales_bridge данные, но через read-only пользователя
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=insales_bridge
MYSQL_USER=bridge_admin_ro
MYSQL_PASSWORD=

# Секрет для подписи сессионных cookie (любая длинная случайная строка)
ADMIN_SESSION_SECRET=change-me-long-random

# Путь к лог-файлам основного бриджа (для просмотра в разделе "Логи")
BRIDGE_LOG_DIR=/var/log/bridge

# Максимум неудачных попыток входа с одного IP за 15 минут, прежде чем блокировать
LOGIN_MAX_ATTEMPTS=5
