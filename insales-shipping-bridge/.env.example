# Скопируйте в .env и заполните

# API перевозчика — https://dev.dellin.ru/api/swagger/
SHIPPING_API_APPKEY=
SHIPPING_API_LOGIN=
SHIPPING_API_PASSWORD=

SHIPPING_REQUESTER_EMAIL=shop@example.com
# SHIPPING_COUNTERAGENT_UID=

# inSales (идентификатор и секрет приложения в партнёрском кабинете)
INSALES_APP_ID=
INSALES_APP_SECRET=

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=insales_bridge
MYSQL_USER=root
MYSQL_PASSWORD=

BRIDGE_SECRET=
CORS_ORIGIN=*

# Публичный URL бриджа (для подсказок checkout в /insales/app)
PUBLIC_BRIDGE_URL=https://your-bridge.example.com

# Секрет для ручной установки /insales/manual-install (если ссылки inSales не работают)
MANUAL_INSTALL_SECRET=change-me-long-random
