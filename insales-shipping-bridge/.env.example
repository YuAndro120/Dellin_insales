# Скопируйте в .env и заполните

# Обязательно для хранения PAT магазинов (страница /insales/app)
BRIDGE_SECRET=change-me-long-random

# Fallback для серверных /v1/* (опционально, если не заданы в приложении магазина)
# API Dellin — https://dev.dellin.ru/api/swagger/
SHIPPING_API_APPKEY=
SHIPPING_API_PAT=
# Устарело: логин/пароль ЛК (v1), используйте PAT
# SHIPPING_API_LOGIN=
# SHIPPING_API_PASSWORD=

SHIPPING_REQUESTER_EMAIL=shop@example.com
# SHIPPING_COUNTERAGENT_UID=

# inSales (идентификатор и секрет приложения в партнёрском кабинете)
INSALES_APP_ID=
INSALES_APP_SECRET=

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=insales_bridge
MYSQL_USER=root
MYSQL_PASSWORD=

CORS_ORIGIN=*

# Публичный URL бриджа (для checkout в inSales)
PUBLIC_BRIDGE_URL=https://your-bridge.example.com

# Секрет для ручной установки /insales/manual-install
MANUAL_INSTALL_SECRET=change-me-long-random
